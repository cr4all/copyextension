{
  "manifest_version": 3,
  "name": "Follow me (westace + gambana)",
  "version": "0.1.0",
  "description": "Capture westace and gambana (Betby) betting requests and forward them to a Socket.IO server.",
  "action": {
    "default_title": "Follow me",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["webRequest", "storage", "alarms", "offscreen", "scripting"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}

